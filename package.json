{
  "name": "bustracking-root",
  "version": "1.0.0",
  "description": "Root project to run frontend and backend concurrently",
  "scripts": {
    "backend": "npm run dev --prefix Backend",
    "frontend": "npm run dev --prefix my-react-app",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
